---
import { ArrowUpRight } from 'lucide-astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomePortal from '../../features/home-portal/HomePortal.astro';
import ArrowLink from '../../components/ArrowLink.astro';
import { locales, type Locale } from '../../config/locales';
import { formatPostDate, getFeaturedPosts, getPostUrl } from '../../data/blog';
import { projects } from '../../data/projects';
export function getStaticPaths() { return locales.map((lang) => ({ params: { lang } })); }
const lang = Astro.params.lang as Locale;
const posts = await getFeaturedPosts(lang, 2);
const copy = lang === 'zh' ? {
  title: '花辞树 — 人格档案与下一次行动',
  description: '穿过过去与未来的两扇门，阅读人格档案、职业方向与支撑选择的内在信念。',
  archive: '项目归档', archiveTitle: '所有行动成果，统一归档。', archiveDescription: '首页只讲述人物与选择；完整案例、过程和成果留在项目归档中。', archiveCount: '已收录案例', archiveLink: '进入项目归档',
  journal: '最近记录', journalLink: '阅读全部记录', read: '阅读记录',
} : {
  title: 'Huacishu — Personal Archive & Next Mission',
  description: 'Step through the doors of past and future to explore a personal archive, professional direction, and the convictions behind every choice.',
  archive: 'Project archive', archiveTitle: 'Every completed mission, archived once.', archiveDescription: 'The homepage tells the person and the choice. Complete cases, process, and outcomes live in the project archive.', archiveCount: 'Cases archived', archiveLink: 'Enter project archive',
  journal: 'Recent logs', journalLink: 'Read all logs', read: 'Read log',
};
---
<BaseLayout title={copy.title} description={copy.description} lang={lang} image={undefined}>
  <HomePortal lang={lang} />

  <section id="work" class="work-gateway section" data-section-anchor>
    <div class="container">
      <header class="section-head"><span class="eyebrow">03 / {copy.archive}</span></header>
      <a class="archive-gateway" href={`/${lang}/projects`} data-reveal>
        <span class="archive-index mono">ARCHIVE / {projects.length.toString().padStart(2, '0')}</span>
        <div class="archive-message"><h2>{copy.archiveTitle}</h2><p>{copy.archiveDescription}</p></div>
        <div class="archive-action">
          <span class="archive-count"><b>{projects.length.toString().padStart(2, '0')}</b><small class="mono">{copy.archiveCount}</small></span>
          <span class="archive-link mono">{copy.archiveLink}<ArrowUpRight /></span>
        </div>
        <span class="archive-mark mono" aria-hidden="true">PROJECT<br />ARCHIVE</span>
      </a>
    </div>
  </section>

  <section id="journal" class="journal-preview section" data-section-anchor>
    <div class="container">
      <header class="section-head"><span class="eyebrow">04 / {copy.journal}</span><ArrowLink href={`/${lang}/journal`} label={copy.journalLink} /></header>
      <div class="home-posts">
        {posts.map((post, index) => <article class="home-post" data-reveal>
          <a href={getPostUrl(post)}>
            <div class="post-num mono">0{index + 1}</div>
            <div><h2>{post.data.title}</h2><p>{post.data.description}</p></div>
            <div class="post-end"><span class="mono">{formatPostDate(post, { year: 'numeric', month: 'short', day: 'numeric' })}</span><ArrowUpRight /></div>
          </a>
        </article>)}
      </div>
    </div>
  </section>
</BaseLayout>
<style>
  .section-head { min-height: 150px; padding-block: 48px; display: flex; justify-content: space-between; align-items: center; gap: 24px; }
  .work-gateway { overflow: hidden; padding-bottom: clamp(110px, 13vw, 190px); }
  .archive-gateway { position: relative; display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: clamp(48px, 9vw, 150px); min-height: clamp(430px, 48vw, 650px); padding: clamp(30px, 5vw, 76px); overflow: hidden; border: 1px solid var(--line); background: var(--ink); color: var(--bg); isolation: isolate; }
  .archive-gateway::before { content: ''; position: absolute; z-index: -1; inset: auto -8% -30% 34%; height: 70%; background: var(--section-color); clip-path: polygon(12% 0, 100% 15%, 88% 100%, 0 82%); transition: transform .7s var(--ease); }
  .archive-gateway:hover::before, .archive-gateway:focus-visible::before { transform: translate(-2%, -5%) rotate(-2deg); }
  .archive-index { grid-column: 1 / -1; align-self: start; color: color-mix(in srgb, var(--bg) 58%, transparent); }
  .archive-message { align-self: end; max-width: 790px; }.archive-message h2 { max-width: 12ch; margin: 0; font-size: var(--type-section-title); line-height: var(--title-line-height); letter-spacing: var(--title-letter-spacing); text-wrap: balance; }.archive-message p { max-width: 590px; margin: 28px 0 0; color: color-mix(in srgb, var(--bg) 68%, transparent); font-size: clamp(16px, 1.5vw, 21px); line-height: 1.6; }
  .archive-action { z-index: 1; align-self: end; display: grid; gap: clamp(56px, 9vw, 120px); min-width: clamp(190px, 20vw, 290px); }.archive-count { display: grid; gap: 8px; }.archive-count b { font: 500 clamp(72px, 9vw, 138px)/.8 'DM Mono', monospace; }.archive-count small { color: color-mix(in srgb, var(--bg) 70%, transparent); }.archive-link { display: flex; align-items: center; justify-content: space-between; gap: 24px; padding-top: 16px; border-top: 1px solid currentColor; }.archive-link svg { width: 30px; height: 30px; transition: transform .3s var(--ease); }.archive-gateway:hover .archive-link svg { transform: translate(5px, -5px); }
  .archive-mark { position: absolute; z-index: -1; right: -1vw; top: 4%; color: transparent; font-size: clamp(70px, 12vw, 180px); font-weight: 500; line-height: .78; text-align: right; -webkit-text-stroke: 1px color-mix(in srgb, var(--bg) 13%, transparent); pointer-events: none; }
  .journal-preview { padding-bottom: 50px; }.home-post { border-top: 1px solid var(--line); }.home-post a { display: grid; grid-template-columns: 70px 1fr auto; gap: 34px; align-items: start; padding-block: 42px; }.post-num { padding-top: 10px; color: var(--muted); }.home-post h2 { margin: 0; font-size: clamp(27px, 3.2vw, 48px); line-height: var(--title-line-height); letter-spacing: var(--title-letter-spacing); font-weight: 500; }.home-post p { margin: 18px 0 0; max-width: 640px; color: var(--muted); line-height: 1.6; }.post-end { display: flex; align-items: center; gap: 26px; color: var(--muted); }.post-end svg { color: var(--ink); }
  @media(max-width:760px) { .section-head { min-height:120px; }.work-gateway { padding-bottom:90px; }.archive-gateway { grid-template-columns:1fr; gap:46px; min-height:580px; padding:28px 24px; }.archive-index { grid-column:1; }.archive-action { gap:38px; min-width:0; }.archive-count b { font-size:76px; }.archive-mark { top:12%; right:-12px; font-size:24vw; }.section-head :global(.rule-link) { font-size:0; gap:0; border:0; padding:12px; }.home-post a { grid-template-columns:36px 1fr; gap:12px; }.post-end { grid-column:2; justify-content:space-between; } }
</style>

