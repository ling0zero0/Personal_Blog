---
import { ArrowLeft, ArrowUpRight } from 'lucide-astro';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionNavigator from '../../../components/SectionNavigator.astro';
import type { Locale } from '../../../data/site';
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { lang: post.data.lang, slug: post.id.split('/').pop() }, props: { post } }));
}
const lang = Astro.params.lang as Locale;
const { post } = Astro.props;
const { Content, headings } = await render(post);
const siblings = allPosts.filter((item) => item.data.lang === lang && item.id !== post.id && item.data.tags.some((tag: string) => post.data.tags.includes(tag))).slice(0, 2);
const format = new Intl.DateTimeFormat(lang === 'zh' ? 'zh-CN' : 'en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
const words = (post.body || '').trim().split(/\s+|(?=[\u4e00-\u9fff])/).length;
const minutes = Math.max(2, Math.ceil(words / (lang === 'zh' ? 350 : 220)));
const copy = lang === 'zh' ? { back: '全部文章', min: '分钟阅读', related: '继续阅读', progress: '阅读进度' } : { back: 'All writing', min: 'min read', related: 'Continue reading', progress: 'Reading progress' };
const sectionItems = headings
  .filter((heading) => heading.depth >= 2 && heading.depth <= 3)
  .map((heading) => ({ id: heading.slug, label: heading.text, depth: heading.depth }));
const canonical = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL('/og.svg', Astro.site);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  keywords: post.data.tags,
  inLanguage: lang === 'zh' ? 'zh-CN' : 'en',
  url: canonical.href,
  image: socialImage.href,
  author: { '@type': 'Person', name: '花辞树', url: new URL(`/${lang}/about`, Astro.site).href },
};
---
<BaseLayout
  title={`${post.data.title} — 花辞树`}
  description={post.data.description}
  lang={lang}
  contentType="article"
  publishedDate={post.data.pubDate}
  tags={post.data.tags}
  jsonLd={jsonLd}
>
  <SectionNavigator lang={lang} items={sectionItems} />
  <div class="reading-progress" role="progressbar" aria-label={copy.progress} aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"><span></span></div>
  <article class="article-shell">
    <header class="article-header" data-reveal-group>
      <div class="front-page container">
        <div class="article-masthead">
          <a class="back-link mono" href={`/${lang}/journal`}><ArrowLeft size={14} />{copy.back}</a>
          <strong>FIELD NOTES</strong>
          <span class="mono">ISSUE / {String(minutes).padStart(2, '0')}</span>
        </div>
        <div class="article-coordinate mono" aria-hidden="true">02 / SIGNAL DOCUMENT / {String(minutes).padStart(2, '0')}</div>
        <div class="article-meta mono" data-reveal><span>{format.format(post.data.pubDate)}</span><span>{minutes} {copy.min}</span><span>{post.data.tags.join(' / ')}</span></div>
        <h1 data-reveal>{post.data.title}</h1>
        <p data-reveal>{post.data.description}</p>
        <div class="panel-mark mono" aria-hidden="true">READ / SCROLL<br />NO. {String(minutes).padStart(2, '0')}</div>
      </div>
    </header>
    <div class="article-layout container">
      <div class="prose"><Content /></div>
    </div>
  </article>
  {siblings.length > 0 && <section class="related section">
    <div class="container"><span class="eyebrow">{copy.related}</span><div class="related-list">{siblings.map((item) => <a href={`/${lang}/journal/${item.id.split('/').pop()}`}><span class="mono">{item.data.tags[0]}</span><h2>{item.data.title}</h2><ArrowUpRight /></a>)}</div></div>
  </section>}
</BaseLayout>
<style is:global>
  .reading-progress { position: fixed; z-index: 100; left: 0; top: 0; width: 100%; height: 3px; background: transparent; }
  .reading-progress span { display: block; width: 100%; height: 100%; background: var(--accent); transform: scaleX(0); transform-origin: left; }
  .article-header { position: relative; overflow: hidden; color: #f7f4ea; background: #0b0c0c; isolation: isolate; }
  .article-header::after { content: ''; position: absolute; inset: auto 0 0; height: 22px; background: var(--section-color); box-shadow: 0 -8px 0 #f7f4ea, 0 -12px 0 #0b0c0c; }
  .front-page { min-height: max(700px, 94svh); padding-top: calc(var(--header-h) + 28px); padding-bottom: 90px; display: grid; grid-template-columns: repeat(12, minmax(0, 1fr)); grid-template-rows: auto auto 1fr auto; gap: 12px; }
  .front-page::before { content: ''; position: absolute; z-index: -1; right: 5vw; top: 20%; width: clamp(220px, 36vw, 570px); aspect-ratio: 1; color: var(--section-color); background: var(--halftone); opacity: .27; clip-path: polygon(50% 0, 100% 25%, 83% 92%, 12% 100%, 0 30%); transform: translate(calc(var(--pointer-x) * -12px), calc(var(--pointer-y) * -12px)) rotate(8deg); }
  .article-masthead { grid-column: 1 / -1; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; padding: 9px 0 14px; border-top: 5px solid #f7f4ea; border-bottom: 1px solid #f7f4ea; }
  .article-masthead strong { font-size: clamp(19px, 2vw, 31px); letter-spacing: -.04em; }
  .article-masthead > span { justify-self: end; color: #ffffffa8; }
  .back-link { display: inline-flex; gap: 8px; align-items: center; width: max-content; color: inherit; }
  .article-coordinate { grid-column: 1 / 4; grid-row: 2; padding: 12px; background: var(--section-color); color: #08100f; font-weight: 700; transform: skewX(-5deg); }
  .article-meta { grid-column: 4 / -1; grid-row: 2; display: flex; justify-content: flex-end; align-items: center; flex-wrap: wrap; gap: 8px 28px; padding: 12px 16px; border: 1px solid #ffffff80; color: #ffffffb5; }
  .article-header h1 { position: relative; z-index: 2; grid-column: 1 / 11; grid-row: 3; align-self: center; margin: 36px 0 48px; padding: clamp(16px, 2vw, 30px) 0; font-size: clamp(68px, 7.5vw, 108px); font-weight: 750; overflow-wrap: break-word; word-break: normal; text-wrap: balance; border-top: 2px solid #f7f4ea; border-bottom: 2px solid #f7f4ea; text-shadow: 8px 8px 0 color-mix(in srgb, var(--section-color) 78%, #000); }
  html[lang='zh'] .article-header h1 { line-height: 1.02; letter-spacing: -.05em; }
  html[lang='en'] .article-header h1 { line-height: .9; letter-spacing: -.06em; }
  .article-header h1::before { content: 'HEADLINE'; position: absolute; top: -24px; left: 0; padding: 5px 9px; background: #f7f4ea; color: #0b0c0c; font: 10px/1 'DM Mono', monospace; letter-spacing: .08em; text-shadow: none; }
  .article-header .front-page > p { position: relative; z-index: 4; grid-column: 7 / -1; grid-row: 4; margin: 0 0 24px; padding: 24px 26px; border: 4px solid #0b0c0c; outline: 1px solid #f7f4ea; background: var(--section-color); color: #07100e; font-size: clamp(19px, 2vw, 29px); line-height: 1.3; font-weight: 550; transform: rotate(-1.2deg); box-shadow: 12px 12px 0 #f7f4ea; }
  .panel-mark { grid-column: 1 / 4; grid-row: 4; align-self: end; padding-left: 14px; border-left: 8px solid var(--section-color); color: #ffffff99; line-height: 1.65; }
  .article-layout { position: relative; display: grid; grid-template-columns: minmax(0, 720px); justify-content: center; padding-top: clamp(90px, 11vw, 160px); padding-bottom: 150px; background: var(--bg); }
  .article-layout::before { content: 'ARTICLE / BODY'; position: absolute; top: 28px; left: var(--pad); color: var(--muted); font: 11px/1 'DM Mono', monospace; letter-spacing: .08em; }
  .prose { width: 100%; font-family: Georgia, 'Noto Sans SC', serif; font-size: 19px; overflow-wrap: break-word; word-break: normal; }
  html[lang='zh'] .prose { max-width: 720px; line-height: 1.82; }
  html[lang='en'] .prose { max-width: 680px; line-height: 1.72; }
  .prose > :first-child { margin-top: 0; }
  .prose h2, .prose h3 { font-family: Inter, 'Noto Sans SC', sans-serif; line-height: 1.2; letter-spacing: 0; scroll-margin-top: 100px; }
  .prose h2 { position: relative; margin: 2.6em 0 .7em; padding-top: 18px; border-top: 1px solid var(--line); font-size: 36px; }
  .prose h2::before { content: ''; position: absolute; left: 0; top: -3px; width: 72px; height: 5px; background: var(--section-color); transform: skewX(-28deg); }
  .prose h3 { margin: 2em 0 .6em; font-size: 25px; }
  .prose p { margin: 0 0 1.5em; }
  .prose strong { color: var(--accent); font-weight: 600; }
  .prose pre { overflow: auto; margin: 2.4em 0; padding: 24px; border-radius: 0; font: 13px/1.7 'DM Mono', monospace; }
  .prose a, .prose code:not(pre code) { overflow-wrap: break-word; word-break: normal; }
  .prose code:not(pre code) { white-space: normal; padding: 2px 5px; background: var(--surface); font: 14px 'DM Mono', monospace; }
  .related-list { margin-top: 50px; border-top: 1px solid var(--line); }
  .related-list a { display: grid; grid-template-columns: 160px 1fr auto; align-items: center; gap: 25px; padding-block: 34px; border-bottom: 1px solid var(--line); }
  .related-list h2 { margin: 0; font-size: clamp(25px, 3vw, 42px); font-weight: 500; }
  @media (max-width: 900px) {
    .article-header h1 { grid-column: 1 / -1; }
    .article-header .front-page > p { grid-column: 5 / -1; }
  }
  @media (max-width: 620px) {
    .front-page { min-height: 100svh; padding-top: calc(var(--header-h) + 18px); padding-bottom: 76px; display: flex; flex-direction: column; gap: 10px; }
    .article-masthead { grid-template-columns: 1fr auto; }
    .article-masthead strong { order: -1; }
    .article-masthead .back-link { grid-column: 1 / -1; grid-row: 2; margin-top: 10px; }
    .article-masthead > span { font-size: 10px; }
    .article-coordinate { align-self: flex-start; font-size: 10px; }
    .article-meta { justify-content: flex-start; padding: 10px; font-size: 11px; }
    .article-header h1 { width: 100%; margin: clamp(34px, 7vh, 70px) 0 26px; font-size: clamp(42px, 14.5vw, 64px); text-shadow: 5px 6px 0 color-mix(in srgb, var(--section-color) 78%, #000); }
    html[lang='zh'] .article-header h1 { line-height: 1.04; letter-spacing: -.045em; }
    html[lang='en'] .article-header h1 { line-height: .92; letter-spacing: -.05em; }
    .article-header .front-page > p { width: 92%; margin: 0 0 0 auto; padding: 18px; font-size: 18px; box-shadow: 7px 7px 0 #f7f4ea; transform: rotate(-.7deg); }
    .panel-mark { margin-top: auto; font-size: 10px; }
    .article-layout { padding-top: 88px; }
    html[lang='zh'] .prose { font-size: 17px; line-height: 1.78; }
    html[lang='en'] .prose { font-size: 17px; line-height: 1.68; }
    .prose h2 { font-size: 29px; }
    .related-list a { grid-template-columns: 1fr auto; }
    .related-list a > span { grid-column: 1 / -1; }
  }
</style>
<script>
  const progress = document.querySelector<HTMLElement>('.reading-progress span'); const progressRoot = document.querySelector<HTMLElement>('.reading-progress');
  function updateReading() { const article = document.querySelector<HTMLElement>('.article-shell'); if (!article || !progress) return; const start = article.offsetTop; const total = article.offsetHeight - innerHeight; const value = Math.max(0, Math.min(1, (scrollY - start) / total)); progress.style.transform = `scaleX(${value})`; progressRoot?.setAttribute('aria-valuenow', String(Math.round(value * 100))); }
  addEventListener('scroll', updateReading, { passive: true }); updateReading();
</script>
