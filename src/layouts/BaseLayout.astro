---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommandPalette from '../components/CommandPalette.astro';
import type { ImageMetadata } from 'astro';
import type { Locale } from '../data/site';
import { ui } from '../data/site';

type Props = {
  title: string;
  description: string;
  lang: Locale;
  image?: string | ImageMetadata;
  contentType?: 'website' | 'article';
  publishedDate?: Date | string;
  tags?: string[];
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  hideFooter?: boolean;
};

const { title, description, lang, image, contentType = 'website', publishedDate, tags = [], jsonLd, hideFooter = false } = Astro.props as Props;
const site = Astro.site ?? Astro.url.origin;
const canonical = new URL(Astro.url.pathname, site);
const imagePath = typeof image === 'string' ? image : image?.src;
const socialImage = new URL(imagePath ?? '/og.svg', site);
const publishedDateIso = publishedDate ? new Date(publishedDate).toISOString() : undefined;
const pathParts = Astro.url.pathname.split('/').filter(Boolean);
const hasLocalizedPath = pathParts[0] === lang;
const localizedUrls = hasLocalizedPath
  ? (['zh', 'en'] as const).map((locale) => {
      const parts = [...pathParts];
      parts[0] = locale;
      return { locale, url: new URL(`/${parts.join('/')}${Astro.url.pathname.endsWith('/') ? '/' : ''}`, site) };
    })
  : [];
const jsonLdSource = jsonLd ? JSON.stringify(jsonLd) : undefined;
const serializedJsonLd = jsonLdSource
  ?.replace(/</g, '\\u003c')
  .replace(/\u2028/g, '\\u2028')
  .replace(/\u2029/g, '\\u2029');
const route = Astro.url.pathname.split('/').filter(Boolean)[1] || 'home';
const section = ['projects', 'journal', 'about'].includes(route) ? route : 'home';
---
<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c0c0b" />
    <link rel="canonical" href={canonical} />
    {localizedUrls.map(({ locale, url }) => <link rel="alternate" hreflang={locale === 'zh' ? 'zh-CN' : 'en'} href={url} />)}
    {hasLocalizedPath && <link rel="alternate" hreflang="x-default" href={localizedUrls.find(({ locale }) => locale === 'en')?.url} />}
    <link rel="alternate" type="application/rss+xml" title="花辞树 / Huacishu Journal" href={new URL('/rss.xml', site)} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preload" href="/fonts/inter-latin-variable.woff2" as="font" type="font/woff2" crossorigin />
    <meta property="og:type" content={contentType} />
    <meta property="og:site_name" content="花辞树" />
    <meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'zh' ? 'en_US' : 'zh_CN'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    {contentType === 'article' && publishedDateIso && <meta property="article:published_time" content={publishedDateIso} />}
    {contentType === 'article' && tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    {serializedJsonLd && <script is:inline type="application/ld+json" set:html={serializedJsonLd} />}
    <title>{title}</title>
  </head>
  <body data-lang={lang} data-section={section}>
    <a href="#main" class="skip-link">{ui[lang].skip}</a>
    <div class="persona-stage" aria-hidden="true">
      <div class="stage-frame" data-depth="back"><i></i><i></i></div>
      <div class="stage-halftone" data-depth="back"></div>
      <div class="stage-shard stage-shard-a" data-depth="mid"></div>
      <div class="stage-shard stage-shard-b" data-depth="front"></div>
      <div class="stage-cross stage-cross-a" data-depth="mid"></div>
      <div class="stage-cross stage-cross-b" data-depth="front"></div>
      <div class="stage-rail"><span>HCS / 2.5D</span><span>31.2304 N</span><span>{section.toUpperCase()} / ACTIVE</span></div>
    </div>
    <Header lang={lang} />
    <main id="main"><slot /></main>
    {!hideFooter && <Footer lang={lang} />}
    <CommandPalette lang={lang} />
    <div class="transition-curtain" aria-hidden="true">
      <i class="curtain-slice curtain-dark"></i><i class="curtain-slice curtain-accent"></i>
      <span>{lang === 'zh' ? '进入下一空间' : 'Entering next space'}</span>
    </div>
    <script>
      import { initShell } from '../scripts/shell';
      initShell();
    </script>
  </body>
</html>
