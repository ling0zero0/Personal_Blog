---
const { slug, index, label = '' } = Astro.props;
---
<div class:list={['project-visual', `visual-${slug}`]} role="img" aria-label={label}>
  <div class="visual-grid"></div>
  {slug === 'latent-atlas' && <><div class="atlas-orbit orbit-a"></div><div class="atlas-orbit orbit-b"></div><div class="atlas-core"></div><div class="visual-data mono">40,892 / VECTOR NODES</div></>}
  {slug === 'second-weather' && <><div class="weather-bars">{Array.from({ length: 18 }).map((_, i) => <i style={`--i:${i}`}></i>)}</div><div class="weather-ring"></div><div class="visual-data mono">PRESSURE / 1008.4 HPA</div></>}
  {slug === 'quiet-machine' && <><div class="machine-frame"><i></i><i></i><i></i><span class="mono">LISTENING<br/>CONFIDENCE .84</span></div><div class="machine-signal"></div><div class="visual-data mono">LOCAL CONTEXT / ACTIVE</div></>}
  <span class="visual-index mono">{index}</span>
</div>
<style>
  .project-visual { position: relative; min-height: 420px; height: min(62vw, 720px); overflow: hidden; background: #11110f; color: #efefe9; isolation: isolate; }
  .visual-grid { position: absolute; inset: -40px; opacity: .16; background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 40px 40px; animation: visual-grid-drift 16s linear infinite; }
  .visual-grid::after { content: ''; position: absolute; inset: 12%; border: 1px solid #ffffff55; }
  .visual-index { position: absolute; z-index: 4; top: 24px; left: 26px; font-size: 13px; }
  .visual-data { position: absolute; z-index: 4; right: 24px; bottom: 22px; color: #ffffff9b; }
  .atlas-orbit { position: absolute; left: 50%; top: 50%; width: 58%; aspect-ratio: 1; border: 1px solid #ffffff88; border-radius: 50%; transform: translate(-50%, -50%) rotateX(68deg) rotateZ(18deg); }
  .orbit-b { width: 39%; border-color: #ff4d24; transform: translate(-50%, -50%) rotateY(64deg) rotateZ(42deg); }
  .orbit-a { animation: orbit-a 13s linear infinite; }
  .orbit-b { animation: orbit-b 9s linear infinite reverse; }
  .atlas-core { position: absolute; left: 50%; top: 50%; width: 18px; height: 18px; background: #ff4d24; box-shadow: 0 0 0 20px #ff4d2422, 0 0 80px 30px #ff4d2444; transform: translate(-50%, -50%) rotate(45deg); animation: core-pulse 3.2s ease-in-out infinite; }
  .weather-bars { position: absolute; inset: 18% 9% 22%; display: flex; align-items: center; gap: 1.8%; }
  .weather-bars i { flex: 1; height: calc(12% + (var(--i) * 4.3%)); max-height: 94%; background: color-mix(in srgb, #37c09d calc(32% + var(--i) * 3%), #efefe9); transform-origin: bottom; animation: weather-wave 3.6s ease-in-out infinite alternate; animation-delay: calc(var(--i) * -120ms); }
  .weather-ring { position: absolute; width: 260px; aspect-ratio: 1; border: 24px solid #e6b422; border-right-color: transparent; border-radius: 50%; left: 55%; top: 44%; transform: translate(-50%, -50%) rotate(-34deg); mix-blend-mode: screen; animation: weather-spin 11s linear infinite; }
  .machine-frame { position: absolute; inset: 18%; border: 1px solid #efefe9; display: grid; place-items: center; }
  .machine-frame::before, .machine-frame::after { content: ''; position: absolute; background: #efefe9; }
  .machine-frame::before { width: 1px; height: 130%; }
  .machine-frame::after { height: 1px; width: 130%; }
  .machine-frame i { position: absolute; border: 1px solid #e6b422; width: 56%; aspect-ratio: 1; border-radius: 50%; }
  .machine-frame i:nth-child(2) { width: 38%; border-color: #ff4d24; }
  .machine-frame i:nth-child(3) { width: 19%; border-color: #37c09d; }
  .machine-frame span { position: relative; z-index: 3; padding: 12px; background: #11110f; text-align: center; line-height: 1.8; }
  .machine-frame i:nth-child(1) { animation: machine-breathe 5s ease-in-out infinite; }
  .machine-frame i:nth-child(2) { animation: machine-breathe 5s 1.3s ease-in-out infinite; }
  .machine-frame i:nth-child(3) { animation: machine-breathe 5s 2.6s ease-in-out infinite; }
  .machine-signal { position: absolute; right: 5%; top: 9%; width: 8px; height: 8px; background: #37c09d; box-shadow: 0 0 20px #37c09d; animation: signal-scan 7s linear infinite; }
  @keyframes visual-grid-drift { to { transform: translate(40px, 40px); } }
  @keyframes orbit-a { to { transform: translate(-50%, -50%) rotateX(68deg) rotateZ(378deg); } }
  @keyframes orbit-b { to { transform: translate(-50%, -50%) rotateY(64deg) rotateZ(402deg); } }
  @keyframes core-pulse { 50% { scale: 1.28; box-shadow: 0 0 0 31px #ff4d2414, 0 0 100px 38px #ff4d2455; } }
  @keyframes weather-wave { to { scale: 1 .7; translate: 0 18px; } }
  @keyframes weather-spin { to { transform: translate(-50%, -50%) rotate(326deg); } }
  @keyframes machine-breathe { 50% { scale: 1.06; opacity: .48; } }
  @keyframes signal-scan { 25% { transform: translate(-78vw, 0); } 50% { transform: translate(-78vw, 50vh); } 75% { transform: translate(0, 50vh); } }
  @media (max-width: 700px) { .project-visual { min-height: 330px; height: 72vw; } .visual-grid::after { inset: 10%; } .machine-frame { inset: 16%; } }
</style>
