---
const { index, label, items = [] } = Astro.props as { index: string; label: string; items?: string[] };
const entries = items.length ? items : ['LIVE INDEX', 'HCS DIGITAL SPACE', '2.5D FIELD'];
---
<div class="signal-band" aria-hidden="true">
  <div class="signal-band-track">
    {[...entries, ...entries].map((item, i) => <span><b>{i % entries.length === 0 ? index : '+'}</b>{item}</span>)}
  </div>
  <i></i>
  <strong>{label}</strong>
</div>
<style>
  .signal-band { position: relative; z-index: 3; width: 100%; max-width: 100vw; height: 76px; overflow: clip; border-block: 1px solid #ffffff36; background: #11110f; color: #f5f2ea; box-shadow: 0 8px 0 var(--section-color); }
  .signal-band::after { content: ''; position: absolute; z-index: 2; left: -3%; bottom: 0; width: 42%; height: 5px; background: var(--section-color); transform: skewX(-30deg); }
  .signal-band-track { position: absolute; inset: 0 auto 0 0; display: flex; align-items: center; width: max-content; animation: signal-travel 22s linear infinite; }
  .signal-band span { display: inline-flex; align-items: center; gap: 18px; min-width: 310px; font: 500 12px 'DM Mono', monospace; }
  .signal-band b { color: var(--section-color); font-size: 18px; }
  .signal-band i { position: absolute; inset: 0 16% 0 auto; width: 10px; background: var(--section-color); transform: skewX(-15deg); box-shadow: 18px 0 0 #f5f2ea; }
  .signal-band strong { position: absolute; right: 22px; top: 50%; padding: 7px 9px; background: #f5f2ea; color: #11110f; font: 600 11px/1.3 'DM Mono', monospace; transform: translateY(-50%); }
  @keyframes signal-travel { to { transform: translateX(-50%); } }
  @media (max-width: 700px) { .signal-band { height: 58px; } .signal-band span { min-width: 250px; } .signal-band strong, .signal-band i { display: none; } }
</style>
