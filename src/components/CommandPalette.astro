---
import { CornerDownLeft, Search, X } from 'lucide-astro';
import type { Locale } from '../config/locales';
const { lang } = Astro.props as { lang: Locale };
const copy = lang === 'zh' ? {
  placeholder: '输入命令，例如“带我看项目”', suggestions: ['带我看项目', '有什么 AI 相关文章', '介绍一下你', '切换到英文'],
  label: '可以试试', hint: '执行命令', close: '关闭', response: '我可以导航、筛选文章和切换语言。',
} : {
  placeholder: 'Type a command, e.g. “show me the work”', suggestions: ['Show me the projects', 'Find articles about AI', 'Tell me about you', 'Switch to Chinese'],
  label: 'Try a command', hint: 'Run command', close: 'Close', response: 'I can navigate, filter writing, and switch languages.',
};
---
<dialog class="command-dialog" id="command-dialog" aria-label={lang === 'zh' ? 'AI 导航命令面板' : 'AI navigation command palette'}>
  <form class="command-form" method="dialog">
    <div class="command-head">
      <Search size={20} />
      <input id="command-input" autocomplete="off" placeholder={copy.placeholder} aria-label={copy.placeholder} />
      <button class="command-close" type="button" value="cancel" aria-label={copy.close}><X size={18} /></button>
    </div>
    <div class="command-body">
      <div class="command-label mono">{copy.label}</div>
      <div class="suggestion-list">
        {copy.suggestions.map((item, i) => <button type="button" class="suggestion" data-command={item}><span>{item}</span><span class="mono">0{i + 1}</span></button>)}
      </div>
      <p class="command-response" aria-live="polite">{copy.response}</p>
    </div>
    <div class="command-hint mono"><span><kbd>ESC</kbd> {copy.close}</span><span><CornerDownLeft size={12} /> {copy.hint}</span></div>
  </form>
</dialog>
