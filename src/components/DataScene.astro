<div class="data-scene" id="data-scene" aria-label="Generative data sculpture">
  <div class="scene-fallback-art" aria-hidden="true"><span></span><span></span><span></span></div>
  <div class="scene-status mono"><span class="scene-live"></span><span>GENERATIVE FIELD / LIVE</span></div>
</div>
<script>
  import type { DataSculpture, SceneQuality } from '../scenes/DataSculpture';

  let sculpture: DataSculpture | undefined;
  let pendingHost: HTMLElement | undefined;
  let idleHandle: number | undefined;
  let timeoutHandle: number | undefined;
  let loadHandler: (() => void) | undefined;

  const showFallback = (host: HTMLElement) => {
    host.classList.add('scene-fallback');
    host.dataset.rendered = 'fallback';
  };

  const getSceneQuality = (): SceneQuality | 'fallback' => {
    const nav = navigator as Navigator & {
      deviceMemory?: number;
      connection?: { saveData?: boolean };
    };
    const cores = nav.hardwareConcurrency || 4;
    const memory = nav.deviceMemory || 4;

    if (matchMedia('(prefers-reduced-motion: reduce)').matches || nav.connection?.saveData || cores <= 2 || memory <= 2) return 'fallback';
    return cores <= 4 || memory <= 4 || innerWidth < 1024 ? 'medium' : 'high';
  };

  const cancelPending = () => {
    if (idleHandle !== undefined && 'cancelIdleCallback' in window) window.cancelIdleCallback(idleHandle);
    if (timeoutHandle !== undefined) window.clearTimeout(timeoutHandle);
    if (loadHandler) removeEventListener('load', loadHandler);
    idleHandle = undefined;
    timeoutHandle = undefined;
    loadHandler = undefined;
  };

  const initializeScene = async (host: HTMLElement, quality: SceneQuality) => {
    if (!('WebGLRenderingContext' in window)) {
      showFallback(host);
      pendingHost = undefined;
      return;
    }

    try {
      const { DataSculpture } = await import('../scenes/DataSculpture');
      if (pendingHost !== host || !host.isConnected) return;
      sculpture = new DataSculpture(host, quality);
      sculpture.init();
    } catch {
      sculpture?.destroy();
      sculpture = undefined;
      showFallback(host);
    } finally {
      if (pendingHost === host) pendingHost = undefined;
    }
  };

  const scheduleScene = () => {
    const host = document.querySelector<HTMLElement>('#data-scene');
    if (!host || host === pendingHost || host === sculpture?.element) return;
    cancelPending();
    sculpture?.destroy();
    sculpture = undefined;

    const quality = getSceneQuality();
    host.dataset.quality = quality;
    if (quality === 'fallback') {
      showFallback(host);
      return;
    }

    pendingHost = host;
    const queueDuringIdle = () => {
      loadHandler = undefined;
      if (!host.isConnected || pendingHost !== host) return;
      if ('requestIdleCallback' in window) {
        idleHandle = window.requestIdleCallback(() => initializeScene(host, quality), { timeout: 2500 });
      } else {
        timeoutHandle = setTimeout(() => initializeScene(host, quality), 200);
      }
    };

    if (document.readyState === 'complete') queueDuringIdle();
    else {
      loadHandler = queueDuringIdle;
      addEventListener('load', loadHandler, { once: true });
    }
  };

  scheduleScene();
  document.addEventListener('astro:page-load', scheduleScene);
  document.addEventListener('astro:before-swap', () => {
    cancelPending();
    pendingHost = undefined;
    sculpture?.destroy();
    sculpture = undefined;
  });
</script>
<style>
  .data-scene { position: absolute; inset: 0; overflow: hidden; background: #0a0a09; }
  .data-scene canvas { position: absolute; inset: 0; width: 100%; height: 100%; }
  .scene-fallback-art { position: absolute; inset: 10%; display: grid; place-items: center; opacity: .7; }
  .scene-fallback-art span { position: absolute; width: min(55vw, 620px); aspect-ratio: 1; border: 1px solid #ffffff29; border-radius: 50%; transform: rotateX(62deg) rotateZ(var(--r)); }
  .scene-fallback-art span:nth-child(1) { --r: 18deg; }
  .scene-fallback-art span:nth-child(2) { --r: 72deg; width: min(42vw, 490px); border-color: #ff4d2444; }
  .scene-fallback-art span:nth-child(3) { --r: 130deg; width: min(30vw, 360px); border-color: #20aa8955; }
  .data-scene[data-rendered='true'] .scene-fallback-art { opacity: 0; }
  .data-scene[data-rendered='fallback'] .scene-live { animation: none; opacity: .45; }
  .scene-status { position: absolute; right: var(--pad); bottom: 28px; z-index: 2; display: flex; gap: 9px; align-items: center; color: #ffffff8a; }
  .scene-live { width: 6px; height: 6px; border-radius: 50%; background: #59d5af; box-shadow: 0 0 10px #59d5af; animation: pulse 2s infinite; }
  @keyframes pulse { 50% { opacity: .35; } }
  @media (prefers-reduced-motion: reduce) { .scene-live { animation: none; } }
</style>
