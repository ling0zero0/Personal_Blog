<div class="data-scene" id="data-scene" aria-label="Generative data sculpture">
  <div class="scene-fallback-art" aria-hidden="true"><span></span><span></span><span></span></div>
  <div class="scene-status mono"><span class="scene-live"></span><span>GENERATIVE FIELD / LIVE</span></div>
</div>
<script>
  import type { DataSculpture } from '../scenes/DataSculpture';

  let sculpture: DataSculpture | undefined;
  let pendingHost: HTMLElement | undefined;

  const initializeScene = async () => {
    const host = document.querySelector<HTMLElement>('#data-scene');
    if (!host || host === pendingHost || host === sculpture?.element) return;
    sculpture?.destroy();
    sculpture = undefined;
    pendingHost = host;

    if (!('WebGLRenderingContext' in window)) {
      host.classList.add('scene-fallback');
      host.dataset.rendered = 'fallback';
      pendingHost = undefined;
      return;
    }

    try {
      const { DataSculpture } = await import('../scenes/DataSculpture');
      if (pendingHost !== host || !host.isConnected) return;
      sculpture = new DataSculpture(host);
      sculpture.init();
    } catch {
      host.classList.add('scene-fallback');
      host.dataset.rendered = 'fallback';
    } finally {
      if (pendingHost === host) pendingHost = undefined;
    }
  };

  initializeScene();
  document.addEventListener('astro:page-load', initializeScene);
  document.addEventListener('astro:before-swap', () => {
    pendingHost = undefined;
    sculpture?.destroy();
    sculpture = undefined;
  });
</script>
<style>
  .data-scene { position: absolute; inset: 0; overflow: hidden; background: #0a0a09; }
  .data-scene canvas { position: absolute; inset: 0; width: 100%; height: 100%; }
  .scene-fallback-art { position: absolute; inset: 10%; display: grid; place-items: center; opacity: .7; }
  .scene-fallback-art span { position: absolute; width: min(55vw, 620px); aspect-ratio: 1; border: 1px solid #ffffff29; border-radius: 50%; transform: rotateX(62deg) rotateZ(var(--r)); }
  .scene-fallback-art span:nth-child(1) { --r: 18deg; }
  .scene-fallback-art span:nth-child(2) { --r: 72deg; width: min(42vw, 490px); border-color: #ff4d2444; }
  .scene-fallback-art span:nth-child(3) { --r: 130deg; width: min(30vw, 360px); border-color: #20aa8955; }
  .data-scene[data-rendered='true'] .scene-fallback-art { opacity: 0; }
  .scene-status { position: absolute; right: var(--pad); bottom: 28px; z-index: 2; display: flex; gap: 9px; align-items: center; color: #ffffff8a; }
  .scene-live { width: 6px; height: 6px; border-radius: 50%; background: #59d5af; box-shadow: 0 0 10px #59d5af; animation: pulse 2s infinite; }
  @keyframes pulse { 50% { opacity: .35; } }
</style>
